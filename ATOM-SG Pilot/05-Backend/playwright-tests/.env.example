# ATOM-SG Playwright Test Configuration
# Copy this file to .env and customize

# Target MVP URL
BASE_URL=http://192.168.2.6

# Mock API Mode
# true = Use mock API for predictable tests (default)
# false = Test against live API (may be flaky, burns credits)
MOCK_API=true

# Skip Live API Tests
# true = Skip live API integration tests (default, recommended for CI)
# false = Run live API tests (use sparingly, manual only)
SKIP_LIVE_API=true

# CI Mode
# true = Running in CI (enables retries, single worker)
# false = Local development
CI=false
