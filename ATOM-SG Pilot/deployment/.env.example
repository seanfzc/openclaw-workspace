# ATOM-SG Pilot MVP - Environment Configuration
# Copy this file to .env and adjust values for your environment

# ============ Server Configuration ============
PORT=5000
HOST=0.0.0.0
DEBUG=false

# ============ OCR Configuration ============
# Tesseract language (default: English)
TESSERACT_LANG=eng

# ============ Rendering Configuration ============
# Default render format (svg, pdf, png)
RENDER_FORMAT=svg

# ============ Database Configuration (Future) ============
# SQLite (default for MVP)
# DATABASE_URL=sqlite:///app/data/atom-sg.db

# PostgreSQL (example)
# DATABASE_URL=postgresql://user:password@localhost:5432/atom_sg

# ============ Security & Secrets ============
# Secret key for session signing (generate with: openssl rand -hex 32)
SECRET_KEY=change_this_to_a_random_secret_key_32_bytes

# ============ Feature Flags ============
# Enable/disable features
ENABLE_GAMING_DETECTION=true
ENABLE_COLLISION_DETECTION=true
ENABLE_MODEL_ARTICULATIONS=true

# ============ Paths ============
# Artifacts directory (relative to backend root)
ARTIFACTS_DIR=artifacts

# ============ External Services (Future) ============
# SMTP for email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# ============ Logging ============
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============ Monitoring ============
# Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/project-id